# Database
DATABASE_URL="file:./dev.db"

# Session Secret (32+ char random string)
SESSION_SECRET="your-session-secret-here"

# AES-256 Encryption Key (32 bytes hex = 64 chars)
ENCRYPTION_KEY="your-64-character-hex-encryption-key-here"

# Gemini AI
GEMINI_API_KEY="your-gemini-api-key-here"

# Resend Email
RESEND_API_KEY="your-resend-api-key-here"
RESEND_FROM_EMAIL="noreply@yourdomain.com"
NOTIFICATION_EMAIL="admin@yourdomain.com"

# RPA Settings
RPA_HEADLESS="true"
RPA_SLOW_MO="0"
RPA_TIMEOUT="30000"

# Hardcoded admin accounts (for MVP)
ADMIN_EMAIL="admin@hr-booleanai.com"
ADMIN_PASSWORD="Admin1234!"
OPERATOR_EMAIL="operator@hr-booleanai.com"
OPERATOR_PASSWORD="Operator1234!"
